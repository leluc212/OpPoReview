{
    "Version":  "2012-10-17",
    "Statement":  [
                      {
                          "Effect":  "Allow",
                          "Resource":  [
                                           "arn:aws:dynamodb:ap-southeast-1:*:table/EmployerProfiles",
                                           "arn:aws:dynamodb:ap-southeast-1:*:table/EmployerProfiles/index/*"
                                       ],
                          "Action":  [
                                         "dynamodb:GetItem",
                                         "dynamodb:PutItem",
                                         "dynamodb:UpdateItem",
                                         "dynamodb:DeleteItem",
                                         "dynamodb:Query",
                                         "dynamodb:Scan"
                                     ]
                      }
                  ]
}
