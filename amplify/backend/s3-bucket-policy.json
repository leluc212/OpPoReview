{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadForCategorizedAssetsOnly",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::opporeview-cv-storage/banner/*",
        "arn:aws:s3:::opporeview-cv-storage/poster/*",
        "arn:aws:s3:::opporeview-cv-storage/system/*",
        "arn:aws:s3:::opporeview-cv-storage/feedback-images/*"
      ]
    }
  ]
}
