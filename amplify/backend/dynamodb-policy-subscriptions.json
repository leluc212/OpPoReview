{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-1:*:table/PackageSubscriptions",
        "arn:aws:dynamodb:ap-southeast-1:*:table/PackageSubscriptions/index/*",
        "arn:aws:dynamodb:ap-southeast-1:*:table/PackageCatalog",
        "arn:aws:dynamodb:ap-southeast-1:*:table/PackageCatalog/index/*",
        "arn:aws:dynamodb:ap-southeast-1:*:table/Notifications",
        "arn:aws:dynamodb:ap-southeast-1:*:table/Notifications/index/*"
      ]
    }
  ]
}
