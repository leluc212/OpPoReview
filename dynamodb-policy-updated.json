{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/CandidateProfiles",
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/CandidateProfiles/index/*",
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/EmployerProfiles",
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/EmployerProfiles/index/*",
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/PostStandardJob",
        "arn:aws:dynamodb:ap-southeast-1:726911960757:table/PostStandardJob/index/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ap-southeast-1:726911960757:*"
    }
  ]
}
