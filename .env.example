# Google Maps API Configuration
# Để sử dụng tính năng geocoding (chuyển đổi địa chỉ thành tọa độ GPS)
# Bạn cần tạo Google Maps API key và bật các dịch vụ sau:
# - Geocoding API
# - Places API (New)
# - Maps JavaScript API (tùy chọn)

REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Hướng dẫn tạo Google Maps API key:
# 1. Truy cập https://console.cloud.google.com/
# 2. Tạo project mới hoặc chọn project hiện có
# 3. Bật các API cần thiết:
#    - Geocoding API
#    - Places API (New)
# 4. Tạo API key trong phần "Credentials"
# 5. Cấu hình restrictions cho API key (khuyến nghị)
# 6. Copy API key và paste vào file .env

# Lưu ý bảo mật:
# - Không commit file .env vào git
# - Sử dụng HTTP referrer restrictions cho production
# - Giới hạn API key chỉ cho các API cần thiết
# - Theo dõi usage để tránh vượt quota

# Other environment variables...

# Banner Management API (deploy via amplify/backend/deploy-banner-lambda.ps1)
# Stores banner metadata in DynamoDB (Banners table) and images in S3 (banner/ folder)
# Max 5 banners can be active at once (enforced on both frontend and Lambda)
VITE_BANNER_API_URL=https://your-banner-api-id.execute-api.ap-southeast-1.amazonaws.com/prod


# Package Subscriptions API
VITE_PACKAGE_SUBSCRIPTIONS_API=https://p0nd7frlhg.execute-api.ap-southeast-1.amazonaws.com

# Notifications API (DynamoDB Backend)
# Chạy script: amplify/backend/create-notifications-lambda.ps1 để tạo API
VITE_NOTIFICATIONS_API=https://your-api-id.execute-api.ap-southeast-1.amazonaws.com

# Experience API (CandidateExperiences feature)
# Chạy script: amplify/backend/deploy-experience-lambda.ps1 để tạo API
VITE_EXPERIENCE_API_URL=https://your-experience-api-id.execute-api.ap-southeast-1.amazonaws.com/prod

# ─── Payments (VietQR + SePay) ───────────────────────────────────────────────
# API Gateway endpoint for payments Lambda
VITE_PAYMENTS_API_URL=https://es3yq2niph.execute-api.ap-southeast-1.amazonaws.com/prod

# CV analysis API Gateway endpoint. The Lambda calls the Gemini API directly
# and does not use AWS Bedrock. Keep GEMINI_API_KEY in the Lambda only.
VITE_CV_AI_API_URL=/api-cv-ai
# Local Vite proxy forwards to the deployed API Gateway.
CV_AI_PROXY_TARGET=https://sd7ds72m8g.execute-api.ap-southeast-1.amazonaws.com/prod

# Admin WebSocket endpoint — dùng cho realtime Yêu Cầu Huỷ Ca
# Chạy script deploy: amplify/backend/deploy-websocket-admin.ps1 để tạo endpoint
# Format: wss://<api-id>.execute-api.ap-southeast-1.amazonaws.com/prod
VITE_ADMIN_WS_ENDPOINT=wss://your-ws-api-id.execute-api.ap-southeast-1.amazonaws.com/prod

# Employer Profile / Admin API
# Use the /api-employer proxy path locally to avoid CORS errors.
# In production set this to the full API Gateway URL.
VITE_EMPLOYER_API_URL=/api-employer

# Lambda environment variables (set in AWS Console or deploy script):
# PAYMENTS_TABLE=Payments
# EMPLOYERS_TABLE=EmployerProfiles
# USER_PACKAGES_TABLE=UserPackages
# VIETQR_BANK_ID=MB                          # Mã ngân hàng VietQR (MB, VCB, TCB...)
# VIETQR_ACCOUNT_NO=0123456789               # Số tài khoản nhận tiền
# VIETQR_ACCOUNT_NAME=CONG%20TY%20OP%20PO   # Tên tài khoản (URL-encoded)
# SEPAY_WEBHOOK_SECRET=your_secret_here      # Secret từ SePay dashboard
